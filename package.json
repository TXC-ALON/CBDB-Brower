{
  "name": "cbdb",
  "version": "1.0.0",
  "description": "CBDB China Biographical Database desktop app (React + Electron + SQLite)",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5174 && set ELECTRON_RUN_AS_NODE=&& electron .",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder --config electron-builder.json",
    "preview": "vite preview",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron ."
  },
  "keywords": [],
  "author": "Codex",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
